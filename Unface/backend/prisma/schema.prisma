generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id   Int    @id @default(autoincrement())
  name String @unique

  users User[]
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  password     String
  schoolId     Int       @map("school_id")
  phoneNumber  String?   @map("phone_number")
  birthDate    DateTime  @map("birth_date")
  chatStatus   String    @default("idle") @map("chat_status") // idle | searching | in_chat
  banStatus    Boolean   @default(false) @map("ban_status")
  policyAgreed Boolean   @default(false) @map("policy_agreed")
  createdAt    DateTime  @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  chatsAsUser1 Chat[] @relation("User1Chats")
  chatsAsUser2 Chat[] @relation("User2Chats")
  messages     Message[]
  reportsSent  Report[] @relation("ReportsFromUser")
}

model Chat {
  id           Int       @id @default(autoincrement())
  user1Id      Int       @map("user1_id")
  user2Id      Int       @map("user2_id")
  status       String    @default("active") // active | closed
  reportStatus String?   @map("report_status") // null | pending | resolved
  createdAt    DateTime  @default(now()) @map("created_at")

  user1    User      @relation("User1Chats", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("User2Chats", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]
  reports  Report[]
}

model Message {
  id        Int      @id @default(autoincrement())
  chatId    Int      @map("chat_id")
  userId    Int      @map("user_id")
  // plaintext оставлен nullable для обратной совместимости/миграции
  text      String?
  textEncrypted Bytes? @map("text_encrypted")
  textIv        Bytes? @map("text_iv")
  textTag       Bytes? @map("text_tag")
  encryptionVersion Int? @map("encryption_version")
  createdAt DateTime @default(now()) @map("created_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id        Int      @id @default(autoincrement())
  chatId    Int      @map("chat_id")
  fromUserId Int     @map("from_user_id")
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  fromUser User @relation("ReportsFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
}
